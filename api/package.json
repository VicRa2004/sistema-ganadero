		"jsonwebtoken": "9.0.3",
		"pg": "8.20.0",
		"reflect-metadata": "0.2.2",
		"swagger-jsdoc": "6.2.8",
		"tsyringe": "4.10.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
