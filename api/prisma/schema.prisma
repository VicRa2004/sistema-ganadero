generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
//  1. Entidades principales
// ─────────────────────────────────────────────

model User {
  id        Int       @id @default(autoincrement()) @map("usr_id")
  email     String    @unique @map("usr_email") @db.VarChar(128)
  name      String    @map("usr_nombre") @db.VarChar(255)
  password  String    @map("usr_password") @db.VarChar(255)
  isActive  Boolean   @default(true) @map("estatus")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  // Relaciones N-a-N gestionadas por tablas intermedias explícitas
  roles             UserRole[]
  directPermissions UserPermission[]
  refreshTokens     RefreshToken[]
  terrenos          Terreno[]
  veterinarios      Veterinario[]

  @@map("user")
}

model Role {
  id          Int       @id @default(autoincrement()) @map("rol_id")
  name        String    @unique @map("rol_nombre") @db.VarChar(150) // e.g., 'ADMIN', 'MOD', 'USER'
  description String?   @map("rol_descripcion") @db.Text
  isActive    Boolean   @default(true) @map("estatus")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("rol")
}

/// Permiso atómico: combinación única de recurso + acción.
/// Ejemplo: resource="turnos", action="create"
model Permission {
  id        Int       @id @default(autoincrement()) @map("per_id")
  resource  String    @map("per_recurso") @db.VarChar(100) // e.g., "turnos", "users"
  action    String    @map("per_accion") @db.VarChar(50) // e.g., "create", "read", "update", "delete"
  isActive  Boolean   @default(true) @map("estatus")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  roles RolePermission[]
  users UserPermission[]

  @@unique([resource, action])
  @@map("permiso")
}

// ─────────────────────────────────────────────
//  2. Tablas intermedias (N-a-N explícitas)
// ─────────────────────────────────────────────

/// Asigna roles a usuarios
model UserRole {
  userId    Int      @map("usrrol_fkuser")
  roleId    Int      @map("usrrol_fkrol")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_rol")
}

/// Permisos que posee un rol completo
model RolePermission {
  roleId       Int @map("rolper_fkrol")
  permissionId Int @map("rolper_fkpermiso")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("rol_permiso")
}

/// Permisos directos o excepcionales por usuario (pueden conceder O denegar)
model UserPermission {
  userId       Int     @map("usrper_fkuser")
  permissionId Int     @map("usrper_fkpermiso")
  /// true = conceder, false = denegar (override sobre el rol)
  granted      Boolean @default(true) @map("usrper_concedido")

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([userId, permissionId])
  @@map("user_permiso")
}

// ─────────────────────────────────────────────
//  3. Refresh Tokens
// ─────────────────────────────────────────────

/// Token de refresco para la rotación segura de sesiones.
/// Se almacena un hash del token, nunca el token en claro.
model RefreshToken {
  id        Int      @id @default(autoincrement()) @map("rft_id")
  tokenHash String   @unique @map("rft_token_hash") @db.VarChar(512)
  userId    Int      @map("rft_fkuser")
  expiresAt DateTime @map("rft_expires_at")
  revoked   Boolean  @default(false) @map("rft_revoked")
  createdAt DateTime @default(now()) @map("rft_created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_token")
}

// ─────────────────────────────────────────────
//  4. Enums de Negocio
// ─────────────────────────────────────────────

enum TipoInsumo {
  MEDICAMENTO
  VACUNA
  ALIMENTO
}

enum SexoGanado {
  MACHO
  HEMBRA
}

// ─────────────────────────────────────────────
//  5. Tablas de Negocio
// ─────────────────────────────────────────────

model Raza {
  id          Int       @id @default(autoincrement()) @map("raz_id")
  nombre      String    @unique @map("raz_nombre") @db.VarChar(100)
  descripcion String?   @map("raz_descripcion") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  ganados Ganado[]

  @@map("raza")
}

model Propietario {
  id          Int       @id @default(autoincrement()) @map("prop_id")
  nombre      String    @map("prop_nombre") @db.VarChar(255)
  telefono    String?   @map("prop_telefono") @db.VarChar(20)
  correo      String?   @map("prop_correo") @db.VarChar(128)
  imagenMarca String?   @map("prop_imagen_marca") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  ganados Ganado[]

  @@map("propietario")
}

model Terreno {
  id                 Int       @id @default(autoincrement()) @map("terr_id")
  nombre             String    @map("terr_nombre") @db.VarChar(150)
  ubicacion          String    @map("terr_ubicacion") @db.VarChar(255)
  extensionHectareas Float     @map("terr_extension")
  capacidadMaxima    Int       @map("terr_capacidad_max")
  imagenTerreno      String?   @map("terr_imagen") @db.VarChar(255)
  usuarioId          Int       @map("terr_fkusuario")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime? @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  usuario            User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  ganados            Ganado[]

  @@map("terreno")
}

model MotivoBaja {
  id          Int       @id @default(autoincrement()) @map("mtb_id")
  nombre      String    @unique @map("mtb_nombre") @db.VarChar(100)
  descripcion String?   @map("mtb_descripcion") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  ganados Ganado[]

  @@map("motivo_baja")
}

model Ganado {
  id              Int        @id @default(autoincrement()) @map("gan_id")
  identificador   String     @unique @map("gan_identificador") @db.VarChar(50)
  peso            Float      @map("gan_peso")
  fechaNacimiento DateTime   @map("gan_fecha_nacimiento") @db.Date
  sexo            SexoGanado @map("gan_sexo")
  imagenGanado    String?    @map("gan_imagen") @db.VarChar(255)
  razaId          Int        @map("gan_fkraza")
  terrenoId       Int        @map("gan_fkterreno")
  propietarioId   Int        @map("gan_fkpropietario")
  padreId         Int?       @map("gan_fkpadre")
  madreId         Int?       @map("gan_fkmadre")
  fechaBaja       DateTime?  @map("gan_fecha_baja")
  motivoBajaId    Int?       @map("gan_fkmotivo_baja")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime?  @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  raza                   Raza                  @relation(fields: [razaId], references: [id], onDelete: Restrict)
  terreno                Terreno               @relation(fields: [terrenoId], references: [id], onDelete: Restrict)
  propietario            Propietario           @relation(fields: [propietarioId], references: [id], onDelete: Restrict)
  padre                  Ganado?               @relation("Linaje_Padre", fields: [padreId], references: [id], onDelete: Restrict)
  madre                  Ganado?               @relation("Linaje_Madre", fields: [madreId], references: [id], onDelete: Restrict)
  hijosComoPadre         Ganado[]              @relation("Linaje_Padre")
  hijosComoMadre         Ganado[]              @relation("Linaje_Madre")
  motivoBaja             MotivoBaja?           @relation(fields: [motivoBajaId], references: [id], onDelete: Restrict)
  aplicacionesSanitarias AplicacionSanitaria[]
  tratamientosMedicos    TratamientoMedico[]

  @@map("ganado")
}

model Insumo {
  id             Int        @id @default(autoincrement()) @map("ins_id")
  nombre         String     @map("ins_nombre") @db.VarChar(150)
  tipo           TipoInsumo @map("ins_tipo")
  stock          Float      @map("ins_stock")
  stockMinimo    Float      @map("ins_stock_minimo")
  unidadMedida   String     @map("ins_unidad") @db.VarChar(20)
  lote           String     @map("ins_lote") @db.VarChar(50)
  fechaCaducidad DateTime   @map("ins_fecha_caducidad")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime?  @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  sesionesSanitarias  SesionSanitaria[]
  tratamientosMedicos TratamientoMedico[]

  @@map("insumo")
}

model SesionSanitaria {
  id            Int       @id @default(autoincrement()) @map("ses_id")
  fecha         DateTime  @map("ses_fecha")
  veterinarioId Int       @map("ses_fkveterinario")
  descripcion   String    @map("ses_descripcion") @db.Text
  insumoId      Int       @map("ses_fkinsumo")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  insumo       Insumo                @relation(fields: [insumoId], references: [id], onDelete: Restrict)
  veterinario  Veterinario           @relation(fields: [veterinarioId], references: [id], onDelete: Restrict)
  aplicaciones AplicacionSanitaria[]

  @@map("sesion_sanitaria")
}

model AplicacionSanitaria {
  id            Int       @id @default(autoincrement()) @map("aps_id")
  sesionId      Int       @map("aps_fksesion")
  ganadoId      Int       @map("aps_fkganado")
  dosisAplicada Float     @map("aps_dosis")
  observaciones String?   @map("aps_observaciones") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")

  sesion SesionSanitaria @relation(fields: [sesionId], references: [id], onDelete: Cascade)
  ganado Ganado          @relation(fields: [ganadoId], references: [id], onDelete: Cascade)

  @@unique([sesionId, ganadoId])
  @@map("aplicacion_sanitaria")
}

model TratamientoMedico {
  id            Int       @id @default(autoincrement()) @map("trt_id")
  ganadoId      Int       @map("trt_fkganado")
  diagnostico   String    @map("trt_diagnostico") @db.VarChar(255)
  fechaInicio   DateTime  @map("trt_fecha_inicio")
  fechaFin      DateTime  @map("trt_fecha_fin")
  activo        Boolean   @default(true) @map("trt_activo")
  insumoId      Int       @map("trt_fkinsumo")
  dosisDiaria   Float     @map("trt_dosis_diaria")
  veterinarioId Int?      @map("trt_fkveterinario")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  ganado      Ganado       @relation(fields: [ganadoId], references: [id], onDelete: Cascade)
  insumo      Insumo       @relation(fields: [insumoId], references: [id], onDelete: Restrict)
  veterinario Veterinario? @relation(fields: [veterinarioId], references: [id], onDelete: Restrict)

  @@map("tratamiento_medico")
}

model Veterinario {
  id                Int       @id @default(autoincrement()) @map("vet_id")
  nombre            String    @map("vet_nombre") @db.VarChar(255)
  telefono          String    @map("vet_telefono") @db.VarChar(20)
  cedulaProfesional String    @unique @map("vet_cedula") @db.VarChar(50)
  especialidad      String?   @map("vet_especialidad") @db.VarChar(100)
  usuarioId         Int       @map("vet_fkusuario")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  usuario             User                @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  sesionesSanitarias  SesionSanitaria[]
  tratamientosMedicos TratamientoMedico[]

  @@map("veterinario")
}
