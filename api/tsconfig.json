{
	"compilerOptions": {
		"baseUrl": ".",
		"rootDir": "./",
		"outDir": "./dist",
		"target": "ESNext", // Bun brilla con lo último de JS
		"module": "ESNext", // Cambiamos de CommonJS a ESNext
		"moduleResolution": "bundler", // La resolución recomendada para Bun
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"noUncheckedIndexedAccess": true,
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"isolatedModules": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
		"strict": true,
		"esModuleInterop": true,

		"allowJs": true,
		"types": ["bun"],
		"lib": ["ESNext"],

		/* Decoradores para tsyringe */
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,

		"ignoreDeprecations": "6.0",
		"paths": {
			"@/*": ["src/*"],
			"@core/*": ["src/core/*"],
			"@shared/*": ["src/shared/*"],
			"@modules/*": ["src/modules/*"]
		},
		"typeRoots": ["src/types", "node_modules/@types"]
	},
	"include": ["src/**/*", "src/types/**/*"],
	"exclude": [
		"node_modules",
		"docs",
		"dist",
		"**/*.spec.ts",
		"**/*.test.ts",
		"**/*.e2e.spec.ts"
	]
}
